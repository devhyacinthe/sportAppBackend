PORT=3001

# football-data.org — free registration at https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_football_data_org_key

# balldontlie.io — free registration at https://app.balldontlie.io
NBA_API_KEY=your_balldontlie_key

# Upstash Redis — free at https://console.upstash.com (optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
